      Production_Quantified_Iterator_Filter,
      Production_Quantified_Iterator_Filter_Missing_Condition_Recovery_Boundary,
      Production_Quantified_Arrow,
      Production_Quantified_Missing_Arrow_Recovery_Boundary,
      Production_Quantified_Missing_Predicate_Recovery_Boundary,
      Production_Quantified_Predicate,
      Production_Declare_Expression,
      Production_Declare_Expression_Declarative_Part,
      Production_Declare_Expression_Begin_Keyword,
      Production_Declare_Expression_Missing_Begin_Recovery_Boundary,
      Production_Declare_Expression_Body_Expression,
      Production_Declare_Expression_Missing_Body_Recovery_Boundary,
      Production_Iterated_Component_Association,
      Production_Iterated_Component_Domain,
      Production_Iterated_Component_Missing_Domain_Recovery_Boundary,
      Production_Iterated_Component_Iterator_Filter,
      Production_Iterated_Component_Iterator_Filter_Missing_Condition_Recovery_Boundary,
      Production_Iterated_Component_Association_Arrow,
      Production_Iterated_Component_Missing_Arrow_Recovery_Boundary,
      Production_Iterated_Component_Expression,
      Production_Iterated_Component_Missing_Expression_Recovery_Boundary,
      Production_Component_Association,
      Production_Association_List,
      Production_Generic_Actual_Part,
      Production_Generic_Actual_Part_Open_Delimiter,
      Production_Generic_Actual_Part_Close_Delimiter,
      Production_Generic_Actual_Association_Separator,
      Production_Generic_Actual_Part_Missing_Close_Recovery_Boundary,
      Production_Generic_Actual_Association,
      Production_Generic_Actual_Positional_Association,
      Production_Generic_Actual_Formal_Selector,
      Production_Generic_Actual_Association_Box,
      Production_Generic_Actual_Missing_Actual_Recovery_Boundary,
      Production_Generic_Actual_Trailing_Separator_Recovery_Boundary,
      Production_Generic_Actual_Empty_List_Recovery_Boundary,
      Production_Generic_Actual_Nested_Actual_Part,
      Production_Generic_Actual_Nested_Actual_Association,
      Production_Generic_Actual_Recovery_Boundary,
      Production_Generic_Actual_Box,
      Production_Recovery_Point);

   type Production_Info is record
      Kind   : Production_Kind := Production_Recovery_Point;
      Line   : Positive := 1;
      Column : Positive := 1;
      Label  : Ada.Strings.Unbounded.Unbounded_String;
   end record;

   type Token_Stream is private;
   type Cursor is private;
   type Grammar_Result is private;

   function Tokenize (Text : String) return Token_Stream;
   function Length (Stream : Token_Stream) return Natural;
   function Token_At (Stream : Token_Stream; Index : Positive) return Token_Info;

   function First (Stream : Token_Stream) return Cursor;
   function At_End (Position : Cursor) return Boolean;
   function Current (Position : Cursor) return Token_Info;
   procedure Advance (Position : in out Cursor);
   function Mark (Position : Cursor) return Natural;
   procedure Restore (Position : in out Cursor; To_Mark : Natural);
   function Match_Keyword (Position : in out Cursor; Keyword : String) return Boolean;
   function Match_Symbol (Position : in out Cursor; Symbol : String) return Boolean;

   function Parse (Text : String) return Grammar_Result;
   function Production_Count (Result : Grammar_Result) return Natural;
   function Production_At
     (Result : Grammar_Result;
      Index  : Positive) return Production_Info;
   function Has_Production
     (Result : Grammar_Result;
      Kind   : Production_Kind) return Boolean;

private
   package Token_Vectors is new Ada.Containers.Vectors
     (Index_Type   => Positive,
      Element_Type => Token_Info);

   package Production_Vectors is new Ada.Containers.Vectors
     (Index_Type   => Positive,
      Element_Type => Production_Info);

   type Token_Stream is record
      Tokens : Token_Vectors.Vector;
   end record;

   type Cursor is record
      Stream : Token_Stream;
      Index  : Positive := 1;
   end record;

   type Grammar_Result is record
      Productions : Production_Vectors.Vector;
   end record;

end Editor.Ada_Token_Cursor;

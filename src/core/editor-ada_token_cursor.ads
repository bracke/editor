with Ada.Containers.Vectors;
with Ada.Strings.Unbounded;

package Editor.Ada_Token_Cursor is

   --  UI-free token-cursor grammar layer for Ada source.  This package is the
   --  grammar-facing parser substrate used by the syntax tree and tests; it is
   --  intentionally bounded/conservative, but it parses by tokens and grammar
   --  synchronization points rather than by rendering or line ownership.

   type Token_Kind is
     (Token_Identifier,
      Token_Keyword,
      Token_String_Literal,
      Token_Character_Literal,
      Token_Numeric_Literal,
      Token_Operator,
      Token_Separator,
      Token_End_Of_Input);

   type Token_Info is record
      Kind   : Token_Kind := Token_End_Of_Input;
      Text   : Ada.Strings.Unbounded.Unbounded_String;
      Lower  : Ada.Strings.Unbounded.Unbounded_String;
      Line   : Positive := 1;
      Column : Positive := 1;
   end record;


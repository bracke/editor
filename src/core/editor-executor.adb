      function Associated_File_Operation_Availability
        (Dirty_Message : String) return Editor.Commands.Command_Availability
      is
         Active_Id : constant Editor.Buffers.Buffer_Id :=
           Editor.Buffers.Global_Active_Buffer;
         Effective_File : Editor.State.File_State := S.File_Info;
         Effective_Has_Buffer : Boolean := Has_Buffer;
      begin
         --  Shared read-only availability policy for the active-buffer
         --  associated-file operation family.  It observes active-buffer
         --  presence, associated-path presence, and dirty state only; it
         --  never validates target paths, probes source/target files, loads
         --  buffers, syncs registry state, executes commands, or mutates
         --  editor/filesystem state.
         if Editor.Buffers.Global_Count = 0
           or else Active_Id = Editor.Buffers.No_Buffer
         then
            return Editor.Commands.Unavailable ("No active buffer.");
         end if;

         if S.Active_Buffer_Token /= Natural (Active_Id) then
            if not Editor.Buffers.Global_Contains (Active_Id) then
               return Editor.Commands.Unavailable ("No active buffer.");
            end if;

            Effective_File :=
              Editor.Buffers.Buffer
                (Editor.Buffers.Global_Registry_For_UI, Active_Id).File_Info;
            Effective_Has_Buffer := True;
         end if;

         if not Effective_Has_Buffer then
            return Editor.Commands.Unavailable ("No active buffer.");
         elsif not Effective_File.Has_Path
           or else Length (Effective_File.Path) = 0
         then
            return Editor.Commands.Unavailable ("No file path for active buffer");
         elsif Effective_File.Dirty then
            return Editor.Commands.Unavailable (Dirty_Message);
         end if;

         return Editor.Commands.Available;
      end Associated_File_Operation_Availability;
   begin
      --  Phase 542: while a destructive dirty lifecycle operation is waiting
      --  for explicit retry/cancel, other guarded lifecycle commands are
      --  unavailable instead of replacing the pending payload through
      --  availability-visible command paths.  Save All, Close Clean, Retry,
      --  and Cancel remain available so the user can resolve the state.

      --  Phase 571 completeness: an active guided prompt owns the current
      --  multi-step workflow.  Availability remains observational, but command
      --  surfaces must not advertise a second lifecycle/destructive/configuration
      --  prompt while the first prompt or confirmation is pending.  Cancel stays
      --  available so the user can leave the modal prompt atomically.
      if Editor.Guided_Prompts.Is_Active (S.Guided_Prompt) then
         --  Phase 571 completeness pass 5: prompt focus is modal at the
         --  command-surface level, not only inside Input_Bridge dispatch.
         --  Confirmation/entry is handled by prompt-local input paths; normal
         --  command availability must not advertise unrelated mutations while
         --  transient prompt input or confirmation payload is active.
         case Id is
            when Command_Cancel =>
               return Editor.Commands.Available;
            when Command_Restore_Workspace_State =>
               return Editor.Commands.Available;
            when No_Command =>
               return Editor.Commands.Unavailable ("No command");
            when others =>
               if Editor.Guided_Prompts.Is_Confirmation (S.Guided_Prompt) then
                  return Editor.Commands.Unavailable
                    ("Command unavailable while confirmation is pending");
               else
                  return Editor.Commands.Unavailable ("Another prompt is active");
               end if;
         end case;
      end if;

      if S.Dirty_Close_Prompt_Active then
         case Id is
            when Command_Confirm_Close_Save =>
               --  Phase 575 completeness pass 16: availability must follow
               --  the same confirmation-time revalidation as execution.  The
               --  prompt snapshot may have been opened when a scratch/all
               --  buffer target was dirty, but the affected buffers can become
               --  clean before confirmation.  In that case save-and-close is
               --  still a valid close confirmation and must not be hidden by
               --  stale stored untitled/file-backed counts.  This check is
               --  purely observational over the in-memory registry.
               if S.Dirty_Close_Prompt_All_Buffers then
                  declare
                     Current : constant Editor.Dirty_Guards.Dirty_Buffer_Summary :=
                       Dirty_Buffer_Summary_For_All_Buffers (S.Project);
                  begin
                     --  Phase 575 completeness pass 21: if the reviewed
                     --  all-buffer set is unchanged but all originally dirty
                     --  buffers became clean before confirmation, save-and-
                     --  close is still a valid close confirmation.  The later
                     --  dirty-fingerprint staleness guard exists to block
                     --  newly dirty/unreviewed text, not to forbid closing a
                     --  now-clean reviewed set.
                     if Current.Dirty_Count = 0 then
                        if Dirty_Close_All_Buffer_Identity_Current (S) then
                           return Editor.Commands.Available;
                        else
                           return Editor.Commands.Unavailable ("Close review is stale");
                        end if;
                     elsif not Dirty_Close_All_Buffer_Review_Current (S) then
                        if not Dirty_Close_All_Buffer_Identity_Current (S)
                          or else not Dirty_Close_Current_Dirty_Set_Was_Reviewed (S)
                        then
                           return Editor.Commands.Unavailable ("Close review is stale");
                        end if;
                     end if;

                     --  Phase 575 completeness pass 25: the reviewed dirty
                     --  set may shrink before confirmation.  Even when that
                     --  revalidation succeeds, save-and-close is still only
                     --  available if at least one remaining dirty buffer can
                     --  use the File_Lifecycle save path.  A remaining
                     --  reviewed scratch-only set must expose discard/cancel,
                     --  not a save action that can only fail.
                     if Current.File_Backed_Count = 0 then
                        return Editor.Commands.Unavailable
                          ("Save As required before saving this buffer");
                     end if;
                  end;
               else
                  declare
                     Target : constant Editor.Buffers.Buffer_Id :=
                       Editor.Buffers.Buffer_Id (S.Dirty_Close_Prompt_Buffer);
                  begin
                     if Target = Editor.Buffers.No_Buffer
                       or else not Editor.Buffers.Global_Contains (Target)
                     then
                        return Editor.Commands.Unavailable
                          ("Selected buffer is no longer open");
                     else
                        declare
                           Summary : constant Editor.Buffers.Buffer_Summary :=
                             Editor.Buffers.Global_Summary_For (Target);
                        begin
                           if not Summary.Is_Dirty then
                              return Editor.Commands.Available;
                           elsif not Summary.Has_Path then
                              --  Phase 575 completeness pass 26: single-buffer
                              --  save-and-close availability is revalidated
                              --  from the live buffer summary, not from the
                              --  original prompt counts.  The target can gain
                              --  or lose a file path while the transient prompt
                              --  is active; availability must match the
                              --  confirmation-time save path exactly.
                              return Editor.Commands.Unavailable
                                ("Save As required before saving this buffer");
                           end if;
                        end;
                     end if;
                  end;
               end if;
               return Editor.Commands.Available;
            when Command_Confirm_Close_Discard =>
               --  Phase 575 completeness pass 17: discard confirmation is
               --  also revalidated against live buffer identity.  A stale
               --  single-target prompt must not advertise a destructive action
               --  for a buffer that no longer exists; cancel remains available
               --  to dismiss the transient review state.
               if S.Dirty_Close_Prompt_All_Buffers then
                  if Editor.Buffers.Global_Count = 0 then
                     return Editor.Commands.Unavailable ("No buffers open");
                  elsif not Dirty_Close_All_Buffer_Review_Current (S) then
                     --  Phase 575 completeness pass 22: mirror the
                     --  execution-time revalidation used by discard.  If
                     --  the reviewed all-buffer identity set is unchanged
                     --  and every reviewed dirty buffer has become clean,
                     --  discard confirmation is no longer destructive but
                     --  remains a valid close confirmation.  Newly dirty
                     --  or replaced buffers still stale the review.
                     if not Dirty_Close_All_Buffer_Identity_Current (S)
                       or else not Dirty_Close_Current_Dirty_Set_Was_Reviewed (S)
                     then
                        return Editor.Commands.Unavailable
                          ("Close review is stale");
                     end if;
                  end if;
               else
                  declare
                     Target : constant Editor.Buffers.Buffer_Id :=
                       Editor.Buffers.Buffer_Id (S.Dirty_Close_Prompt_Buffer);
                  begin
                     if Target = Editor.Buffers.No_Buffer
                       or else not Editor.Buffers.Global_Contains (Target)
                     then
                        return Editor.Commands.Unavailable
                          ("Selected buffer is no longer open");
                     end if;
                  end;
               end if;
               return Editor.Commands.Available;
            when Command_Cancel_Close
               | Command_Cancel =>
               return Editor.Commands.Available;
            when No_Command =>
               return Editor.Commands.Unavailable ("No command");
            when others =>
               return Editor.Commands.Unavailable
                 ("Command unavailable while confirmation is pending");
         end case;
      end if;

      if S.File_Conflict_Prompt_Active then
         --  Phase 574: the conflict prompt owns the current file lifecycle
         --  decision.  Availability remains side-effect-free: it only exposes
         --  the no-payload conflict actions and generic cancel, and it never
         --  probes or resolves the filesystem.
         case Id is
            when Command_File_Conflict_Overwrite_Disk =>
               if not S.File_Conflict_Prompt_Dirty then
                  return Editor.Commands.Unavailable ("Buffer is not dirty");
               end if;
            when Command_File_Conflict_Keep_Buffer
               | Command_File_Conflict_Reload_From_Disk
               | Command_File_Conflict_Cancel
               | Command_Cancel =>
               null;
            when No_Command =>
               return Editor.Commands.Unavailable ("No command");
            when others =>
               return Editor.Commands.Unavailable
                 ("Command unavailable while confirmation is pending");
         end case;
      end if;

      if Editor.Pending_Transitions.Has_Pending (S.Pending_Transitions) then
         if File_Lifecycle_Confirmation_Pending (S) then
            --  Phase 573 completeness: dirty reload/revert confirmations are
            --  lifecycle-scoped modal prompts.  The pending bar exposes only
            --  Retry/Cancel, so direct Executor and Command Palette routes must
            --  not allow save/save-as or adjacent file mutation commands to
            --  resolve or replace the captured dirty-buffer payload behind the
            --  confirmation.  Generic transition confirmations retain their
            --  broader Save All / Close Clean actions below.
            case Id is
               when Command_Save_File
                  | Command_Save_File_As
                  | Command_Save_All
                  | Command_Open_File
                  | Command_Accept_Quick_Open
                  | Command_Quick_Open_Create_From_Query
                  | Command_Quick_Open_Create_With_Parents_From_Query
                  | Command_Accept_Buffer_Switcher
                  | Command_Buffer_Switcher_Selected_Close
                  | Command_Buffer_Switcher_Mark_Close_Marked
                  | Command_Next_Buffer
                  | Command_Previous_Buffer
                  | Command_Next_Recent_Buffer
                  | Command_Previous_Recent_Buffer
                  | Command_Switch_Buffer
                  | Command_File_Tree_Open_Selected
                  | Command_File_Tree_Create_File
                  | Command_File_Tree_Create_Directory
                  | Command_File_Tree_Rename_Selected
                  | Command_File_Tree_Delete_Selected
                  | Command_Close_All_Clean_Buffers
                  | Command_Rename_Buffer_File
                  | Command_Delete_Buffer_File
                  | Command_Copy_Buffer_File
                  | Command_Move_Buffer_File
                  | Command_Insert_Newline
                  | Command_Undo
                  | Command_Redo
                  | Command_Edit_History_Clear
                  | Command_Cut
                  | Command_Paste
                  | Command_Selection_Delete
                  | Command_Line_Delete
                  | Command_Line_Duplicate
                  | Command_Line_Move_Up
                  | Command_Line_Move_Down
                  | Command_Indent_Increase
                  | Command_Indent_Decrease
                  | Command_Comment_Line
                  | Command_Uncomment_Line
                  | Command_Toggle_Line_Comment
                  | Command_Line_Join_Next
                  | Command_Line_Split_At_Caret
                  | Command_Trim_Trailing_Whitespace
                  | Command_Char_Delete_Previous
                  | Command_Char_Delete_Next
                  | Command_Word_Delete_Previous
                  | Command_Word_Delete_Next
                  | Command_Replace_Current
                  | Command_Replace_All =>
                  return Editor.Commands.Unavailable
                    ("Command unavailable while confirmation is pending");
               when others =>
                  null;
            end case;
         end if;

         case Id is
            when Command_Close_All_Buffers
               | Command_Close_Other_Buffers
               | Command_Reload_Active_Buffer
               | Command_Revert_Active_Buffer
               | Command_Close_Active_Buffer
               | Command_Open_Project
               | Command_Switch_Project
               | Command_Open_Selected_Recent_Project
               | Command_Close_Project
               | Command_Clear_Project
               | Command_Restore_Workspace_State
               | Command_Project_Search_Replace_Preview
               | Command_Project_Search_Replace_Toggle_Selected
               | Command_Project_Search_Replace_Include_Selected
               | Command_Project_Search_Replace_Exclude_Selected
               | Command_Project_Search_Replace_Include_File
               | Command_Project_Search_Replace_Exclude_File
               | Command_Project_Search_Replace_Include_All
               | Command_Project_Search_Replace_Exclude_All
               | Command_Project_Search_Replace_Selected
               | Command_Project_Search_Replace_All_Included =>
               return Editor.Commands.Unavailable
                 ("Command unavailable while confirmation is pending");
            when others =>
               null;
         end case;
      end if;

      case Id is
         when No_Command =>
            return Editor.Commands.Unavailable ("No command selected");

         when Command_Save_File =>
            declare
               Active_Id : constant Editor.Buffers.Buffer_Id :=
                 Editor.Buffers.Global_Active_Buffer;
               Effective_File : Editor.State.File_State := S.File_Info;
               Effective_Has_Buffer : Boolean := Has_Buffer;
            begin
               --  Availability must observe the same active-buffer identity
               --  that execution would use, but it must remain read-only:
               --  do not load the active buffer into S, do not sync stale
               --  state into the registry, and do not touch filesystem state.
               if Editor.Buffers.Global_Registry_Current_For (S)
                 and then Editor.Buffers.Global_Count > 0
                 and then Active_Id /= Editor.Buffers.No_Buffer
                 and then S.Active_Buffer_Token /= Natural (Active_Id)
               then
                  if not Editor.Buffers.Global_Contains (Active_Id) then
                     return Editor.Commands.Unavailable ("No active buffer.");
                  end if;

                  Effective_File :=
                    Editor.Buffers.Buffer
                      (Editor.Buffers.Global_Registry_For_UI, Active_Id).File_Info;
                  Effective_Has_Buffer := True;
               end if;

               if not Effective_Has_Buffer then
                  return Editor.Commands.Unavailable ("No active buffer.");
               elsif not Effective_File.Has_Path
                 or else Length (Effective_File.Path) = 0
               then
                  return Editor.Commands.Unavailable ("No file path for active buffer");
               elsif Effective_File.Dirty then
                  null;
               else
                  return Editor.Commands.Unavailable ("No changes to save");
               end if;

               return Editor.Commands.Available;
            end;

         when Command_File_Conflict_Keep_Buffer
            | Command_File_Conflict_Reload_From_Disk
            | Command_File_Conflict_Overwrite_Disk
            | Command_File_Conflict_Cancel =>
            if not S.File_Conflict_Prompt_Active then
               return Editor.Commands.Unavailable ("No active file conflict");
            else
               --  Phase 574 completeness: conflict actions must remain
               --  executable while a prompt is active so the Executor handler
               --  can revalidate and reject stale prompts as a command
               --  outcome.  Returning unavailable for stale prompts here
               --  would leave the transient prompt modal and uncleared,
               --  blocking unrelated commands until a separate generic
               --  cancel route is found.  Availability therefore answers
               --  only whether there is an active file-conflict decision;
               --  the mutation boundary below performs the stale check and
               --  clears the prompt without touching disk or buffer text.
               return Editor.Commands.Available;
            end if;

         when Command_Reveal_Active_File_In_Tree =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            elsif not S.File_Info.Has_Path or else Length (S.File_Info.Path) = 0 then
               return Editor.Commands.Unavailable ("Active buffer has no file path");
            elsif not Editor.Project.Has_Project (S.Project) then
               return Editor.Commands.Unavailable ("No project open");
            elsif not Editor.Project.Is_Under_Project
              (S.Project, To_String (S.File_Info.Path))
            then
               return Editor.Commands.Unavailable
                 ("Active file is outside the current project");
            elsif Editor.File_Tree.Is_Empty (S.File_Tree) then
               return Editor.Commands.Unavailable ("File Tree unavailable");
            end if;
            return Editor.Commands.Available;

         when Command_Reload_Active_Buffer =>
            declare
               Active_Id : constant Editor.Buffers.Buffer_Id :=
                 Editor.Buffers.Global_Active_Buffer;
               Effective_File : Editor.State.File_State := S.File_Info;
               Effective_Has_Buffer : Boolean := Has_Buffer;
            begin
               --  Availability mirrors file.reload-buffer execution target
               --  resolution without loading, syncing, reading, probing, or
               --  mutating any editor or filesystem state.
               if Editor.Buffers.Global_Count = 0
                 or else Active_Id = Editor.Buffers.No_Buffer
               then
                  return Editor.Commands.Unavailable ("No active buffer.");
               end if;

               if S.Active_Buffer_Token /= Natural (Active_Id) then
                  if not Editor.Buffers.Global_Contains (Active_Id) then
                     return Editor.Commands.Unavailable ("No active buffer.");
                  end if;

                  Effective_File :=
                    Editor.Buffers.Buffer
                      (Editor.Buffers.Global_Registry_For_UI, Active_Id).File_Info;
                  Effective_Has_Buffer := True;
               end if;

               if not Effective_Has_Buffer then
                  return Editor.Commands.Unavailable ("No active buffer.");
               elsif not Effective_File.Has_Path
                 or else Length (Effective_File.Path) = 0
               then
                  return Editor.Commands.Unavailable ("No file path for active buffer");
               elsif Effective_File.Dirty then
                  return Editor.Commands.Unavailable
                    ("Dirty buffer cannot be reloaded");
               end if;

               return Editor.Commands.Available;
            end;

         when Command_Revert_Active_Buffer =>
            declare
               Active_Id : constant Editor.Buffers.Buffer_Id :=
                 Editor.Buffers.Global_Active_Buffer;
               Effective_File : Editor.State.File_State := S.File_Info;
               Effective_Has_Buffer : Boolean := Has_Buffer;
            begin
               --  Availability mirrors file.revert-buffer execution target
               --  resolution without loading, syncing, reading, probing, or
               --  mutating any editor or filesystem state.
               if Editor.Buffers.Global_Count = 0
                 or else Active_Id = Editor.Buffers.No_Buffer
               then
                  return Editor.Commands.Unavailable ("No active buffer.");
               end if;

               if S.Active_Buffer_Token /= Natural (Active_Id) then
                  if not Editor.Buffers.Global_Contains (Active_Id) then
                     return Editor.Commands.Unavailable ("No active buffer.");
                  end if;

                  Effective_File :=
                    Editor.Buffers.Buffer
                      (Editor.Buffers.Global_Registry_For_UI, Active_Id).File_Info;
                  Effective_Has_Buffer := True;
               end if;

               if not Effective_Has_Buffer then
                  return Editor.Commands.Unavailable ("No active buffer.");
               elsif not Effective_File.Has_Path
                 or else Length (Effective_File.Path) = 0
               then
                  return Editor.Commands.Unavailable ("No file path for active buffer");
               elsif not Effective_File.Dirty then
                  return Editor.Commands.Unavailable
                    ("No changes to revert");
               end if;

               return Editor.Commands.Available;
            end;

         when Command_Rename_Buffer_File =>
            return Associated_File_Operation_Availability
              ("Dirty buffer file cannot be renamed");

         when Command_Delete_Buffer_File =>
            return Associated_File_Operation_Availability
              ("Dirty buffer file cannot be deleted");

         when Command_Copy_Buffer_File =>
            return Associated_File_Operation_Availability
              ("Dirty buffer file cannot be copied");

         when Command_Move_Buffer_File =>
            return Associated_File_Operation_Availability
              ("Dirty buffer file cannot be moved");

         when Command_Save_File_As =>
            if Editor.Buffers.Global_Count = 0
              or else Editor.Buffers.Global_Active_Buffer = Editor.Buffers.No_Buffer
            then
               return Editor.Commands.Unavailable ("No active buffer.");
            end if;
            return Editor.Commands.Available;

         when Command_Toggle_Bookmark
            | Command_Move_Left
            | Command_Move_Right
            | Command_Move_Up
            | Command_Move_Down
            | Command_Move_Line_Start
            | Command_Move_Line_End
            | Command_Move_Document_Start
            | Command_Move_Document_End
            | Command_Move_Word_Left
            | Command_Move_Word_Right
            | Command_Page_Up
            | Command_Page_Down
            | Command_Select_Left
            | Command_Select_Right
            | Command_Select_Up
            | Command_Select_Down
            | Command_Select_Word_Left
            | Command_Select_Word_Right
            | Command_Select_Word
            | Command_Select_Line
            | Command_Start_Rectangular_Selection
            | Command_Clear_Rectangular_Selection
            | Command_Extend_Selection_Line_Up
            | Command_Extend_Selection_Line_Down
            | Command_Select_Line_Start
            | Command_Select_Line_End
            | Command_Select_Document_Start
            | Command_Select_Document_End
            | Command_Select_Page_Up
            | Command_Select_Page_Down
            | Command_Insert_Newline
            | Command_Goto_Start
            | Command_Goto_End =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            end if;
            return Editor.Commands.Available;

         when Command_Copy =>
            return Editor.Executor.Clipboard.Copy_Cut_Availability (S);

         when Command_Cut =>
            return Editor.Executor.Clipboard.Copy_Cut_Availability (S);

         when Command_Paste =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            elsif not Editor.Clipboard.Has_Text then
               return Editor.Commands.Unavailable ("Clipboard is empty");
            end if;
            return Editor.Commands.Available;

         when Command_Clipboard_Clear =>
            if not Editor.Clipboard.Has_Text then
               return Editor.Commands.Unavailable ("Clipboard is empty");
            end if;
            return Editor.Commands.Available;

         when Command_Select_All =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            end if;
            return Editor.Commands.Available;

         when Command_Selection_Clear =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            elsif S.Carets.Length = 0 then
               return Editor.Commands.Unavailable ("No caret location");
            elsif not Editor.Selection.Has_Selection (S)
              and then not S.Rect_Select_Active
            then
               return Editor.Commands.Unavailable ("No selection");
            end if;
            return Editor.Commands.Available;

         when Command_Selection_Delete =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            elsif S.Carets.Length = 0 then
               return Editor.Commands.Unavailable ("No caret location");
            end if;
            return Editor.Commands.Available;

         when Command_Trim_Trailing_Whitespace =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            elsif S.Carets.Length = 0 then
               return Editor.Commands.Unavailable ("No caret location");
            elsif not Trim_Trailing_Whitespace_Would_Change then
               return Editor.Commands.Unavailable ("No trailing whitespace");
            end if;
            return Editor.Commands.Available;

         when Command_Line_Delete
            | Command_Line_Duplicate
            | Command_Line_Move_Up
            | Command_Line_Move_Down
            | Command_Indent_Increase
            | Command_Indent_Decrease
            | Command_Comment_Line
            | Command_Uncomment_Line
            | Command_Toggle_Line_Comment
            | Command_Line_Join_Next
            | Command_Line_Split_At_Caret
            | Command_Char_Delete_Previous
            | Command_Char_Delete_Next
            | Command_Word_Delete_Previous
            | Command_Word_Delete_Next =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            elsif S.Carets.Length = 0 then
               return Editor.Commands.Unavailable ("No caret location");
            end if;
            return Editor.Commands.Available;

         when Command_Goto_Line
            | Command_Goto_Line_Toggle =>
            return Editor.Commands.Available;

         when Command_Goto_Line_Prefill_Current =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            elsif S.Carets.Length = 0 or else Editor.State.Line_Count (S) = 0 then
               return Editor.Commands.Unavailable ("No current caret location");
            end if;
            return Editor.Commands.Available;

         when Command_Navigation_Back =>
            if not Editor.Navigation_History.Has_Back (S.Navigation_History) then
               return Editor.Commands.Unavailable ("No previous navigation location");
            end if;
            return Editor.Commands.Available;

         when Command_Navigation_Forward =>
            if not Editor.Navigation_History.Has_Forward (S.Navigation_History) then
               return Editor.Commands.Unavailable ("No next navigation location");
            end if;
            return Editor.Commands.Available;

         when Command_Navigation_History_Clear =>
            if not Editor.Navigation_History.Has_Back (S.Navigation_History)
              and then not Editor.Navigation_History.Has_Forward (S.Navigation_History)
            then
               return Editor.Commands.Unavailable ("No navigation history");
            end if;
            return Editor.Commands.Available;

         when Command_Confirm_Close_Save
            | Command_Confirm_Close_Discard
            | Command_Cancel_Close =>
            if S.Dirty_Close_Prompt_Active then
               return Editor.Commands.Available;
            end if;
            return Editor.Commands.Unavailable ("No close confirmation pending");

         when Command_Reopen_Closed_Buffer =>
            if S.Has_Reopen_Candidate and then Length (S.Reopen_Candidate_Path) > 0 then
               return Editor.Commands.Available;
            end if;
            return Editor.Commands.Unavailable ("No closed buffer to reopen");

         when Command_Close_Active_Buffer =>
            declare
               Active_Id : constant Editor.Buffers.Buffer_Id :=
                 Editor.Buffers.Global_Active_Buffer;
               Effective_File : Editor.State.File_State := S.File_Info;
            begin
               --  Phase 430: availability observes the buffer that execution
               --  would close, without syncing or repairing state.
               if Editor.Buffers.Global_Count = 0
                 or else Active_Id = Editor.Buffers.No_Buffer
               then
                  return Editor.Commands.Unavailable ("No active buffer.");
               end if;

               if S.Active_Buffer_Token /= Natural (Active_Id) then
                  if not Editor.Buffers.Global_Contains (Active_Id) then
                     return Editor.Commands.Unavailable ("No active buffer.");
                  end if;
                  Effective_File :=
                    Editor.Buffers.Buffer
                      (Editor.Buffers.Global_Registry_For_UI, Active_Id).File_Info;
               elsif not Has_Buffer then
                  return Editor.Commands.Unavailable ("No active buffer.");
               end if;

               --  Phase 575: dirty active close is available because execution
               --  opens an explicit save/discard/cancel review instead of
               --  silently discarding text.
               return Editor.Commands.Available;
            end;

         when Command_Close_Other_Buffers =>
            if Editor.Buffers.Global_Count = 0 then
               return Editor.Commands.Unavailable ("No active buffer.");
            elsif not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            end if;
            return Editor.Commands.Available;

         when Command_Project_Search_From_Selection
            =>
            if not Has_Project then
               return Editor.Commands.Unavailable ("No project open");
            elsif Editor.Project.Known_File_Count (S.Project) = 0 then
               return Editor.Commands.Unavailable ("No project open.");
            elsif not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            elsif not Has_Selection then
               return Editor.Commands.Unavailable ("No selected text");
            end if;
            return Editor.Commands.Available;

         when Command_Project_Search_From_Active_Word
            | Command_Project_Search_Active_Directory =>
            if not Has_Project then
               return Editor.Commands.Unavailable ("No project open");
            elsif Editor.Project.Known_File_Count (S.Project) = 0 then
               return Editor.Commands.Unavailable ("No project open.");
            elsif not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            end if;
            return Editor.Commands.Available;

         when Command_Find_From_Selection =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            elsif not Has_Selection then
               return Editor.Commands.Unavailable ("No selected text");
            end if;
            return Editor.Commands.Available;

         when Command_Find_From_Active_Word =>
            if not Has_Buffer then
               return Editor.Commands.Unavailable ("No active buffer.");
            end if;
            return Editor.Commands.Available;

         when Command_Save_All =>
            if Editor.Buffers.Global_Dirty_File_Backed_Buffer_Count = 0
              and then not (S.File_Info.Dirty and then S.File_Info.Has_Path)
            then
               return Editor.Commands.Unavailable (Editor.Dirty_Guards.No_Dirty_File_Backed_Buffers_Message);
            end if;
            return Editor.Commands.Available;

         when Command_Close_All_Buffers =>
            if Editor.Buffers.Global_Count = 0 then
               return Editor.Commands.Unavailable ("No buffers to close");
            end if;

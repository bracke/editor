   begin
      if Ada.Strings.Fixed.Index (C, " at ") /= 0
        or else Ada.Strings.Fixed.Index (T, "'address") /= 0
      then
         return Representation_Address_Clause;
      elsif Ada.Strings.Fixed.Index (T, "'size") /= 0 then

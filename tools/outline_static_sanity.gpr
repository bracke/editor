project Outline_Static_Sanity is
   for Source_Dirs use (".");
   for Object_Dir use "obj/outline_static_sanity";
   for Exec_Dir use "bin";
   for Main use ("outline_static_sanity.adb");
   for Languages use ("Ada");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnatyM120");
   end Compiler;
end Outline_Static_Sanity;

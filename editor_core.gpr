with "textrender.gpr";
library project Editor_Core is

   for Source_Dirs use ("src/core", "../guikit/src");
   for Source_List_File use "config/editor_core_sources.lst";
   for Object_Dir use "obj/core";
   for Library_Dir use "obj/core/lib";
   for Library_Name use "editor_core";
   for Library_Kind use "static";

   for Languages use ("Ada");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022");
   end Compiler;

end Editor_Core;

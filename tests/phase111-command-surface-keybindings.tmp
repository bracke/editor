editor-keybindings-version=1
[bindings]
bookmarks.clear-buffer=Ctrl+Shift+F2
bookmarks.next=F2
bookmarks.previous=Shift+F2
bookmarks.toggle=Ctrl+F2
buffers.recent.next=Ctrl+Shift+Tab
buffers.recent.previous=Ctrl+Tab
cancel=Escape
edit.char.delete-next=Delete
edit.char.delete-previous=Backspace
edit.copy=Ctrl+C
edit.cut=Ctrl+X
edit.find.next=F3
edit.find.previous=Shift+F3
edit.find.show=Ctrl+F
edit.paste=Ctrl+V
edit.redo=Ctrl+Y
edit.undo=Ctrl+Z
edit.word.delete-next=Ctrl+Delete
edit.word.delete-previous=Ctrl+Backspace
file.close-buffer=Ctrl+W
file.save=Ctrl+S
file.save-as=Ctrl+Shift+S
insert-newline=Enter
move-document-end=Ctrl+End
move-document-start=Ctrl+Home
move-down=Down
move-left=Left
move-line-end=End
move-line-start=Home
move-right=Right
move-up=Up
move-word-left=Ctrl+Left
move-word-right=Ctrl+Right
navigation.back=Alt+Left
navigation.forward=Alt+Right
navigation.goto-line.show=Ctrl+G
new-buffer=Ctrl+N
open-command-palette=Ctrl+Shift+P
outline.open-selected=Alt+Enter
outline.refresh=Ctrl+F12
outline.reveal-current-symbol=Alt+Shift+F12
page-down=PageDown
page-up=PageUp
project.quick-open.show=Ctrl+P
project.search.show=Ctrl+Shift+F
select-current-outline-symbol=Alt+F12
select-next-outline-item=Alt+F3
select-page-down=Shift+PageDown
select-page-up=Shift+PageUp
select-previous-outline-item=Alt+Shift+F3
selection.extend-buffer-end=Ctrl+Shift+End
selection.extend-buffer-start=Ctrl+Shift+Home
selection.extend-down=Shift+Down
selection.extend-left=Shift+Left
selection.extend-line-end=Shift+End
selection.extend-line-start=Shift+Home
selection.extend-right=Shift+Right
selection.extend-up=Shift+Up
selection.extend-word-left=Ctrl+Shift+Left
selection.extend-word-right=Ctrl+Shift+Right
selection.select-all=Ctrl+A
selection.select-line=Ctrl+L
toggle-problems-panel=Ctrl+Shift+M

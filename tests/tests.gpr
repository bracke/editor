with "config/tests_config.gpr";
with "../editor_core.gpr";

project Tests is

   for Source_Dirs use ("src/", "config/", "../src/core");
   for Excluded_Source_Files use
     ("editor.ads",
      "editor-runtime_c_api.ads",
      "editor-runtime_c_api.adb");
   for Object_Dir use "obj/" & Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("tests.adb");

   for Languages use ("Ada");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnatX", "-gnata");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Tests;

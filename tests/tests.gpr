with "config/tests_config.gpr";
with "../editor_core.gpr";

project Tests is

   for Source_Dirs use ("src/", "config/", "../tools");
   for Object_Dir use "obj/" & Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use
     ("tests.adb",
      "editor_core_tests.adb",
      "executor_diagnostics_tests.adb",
      "executor_search_tests.adb",
      "executor_navigation_tests.adb",
      "executor_buffer_switcher_tests.adb",
      "executor_buffer_prune_tests.adb",
      "executor_lifecycle_tests.adb",
      "editor_ui_tests.adb",
      "project_workspace_tests.adb",
      "diagnostics_problems_tests.adb",
      "build_tools_tests.adb",
      "ada_parser_outline_tests.adb",
      "ada_language_service_tests.adb",
      "ada_language_tests.adb",
      "ada_rm_validation_tests.adb",
      "text_tests.adb");

   for Languages use ("Ada");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnatX", "-gnata");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Tests;

        "   use Shared.Helpers, Shared.More;" & ASCII.LF &
        "   use type Shared.Count, Interfaces.Unsigned_32;" & ASCII.LF &
        "   use all type Shared.Count'Class, Interfaces.Integer_32;" & ASCII.LF &
        "   Value : Integer;" & ASCII.LF &

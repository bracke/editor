        "package body Client is" & ASCII.LF &
        "   function Make_Integer (X : Integer) return Integer is (X);" & ASCII.LF &
        "   function Make_Flag (X : Integer) return Boolean is (True);" & ASCII.LF &
        "   procedure Touch (X : Integer) is null;" & ASCII.LF &

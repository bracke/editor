         Lifecycle_Generation => 0, Analysis => Lib_Analysis);
      Editor.Ada_Project_Index.Put_Analysis
        (Index, "src/lim.ads", Buffer_Token => 0, Buffer_Revision => 0,
         Lifecycle_Generation => 0, Analysis => Limited_Analysis);

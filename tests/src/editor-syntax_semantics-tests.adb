      Source : constant String :=
        "package Root is" & ASCII.LF &
        "   package Internal is" & ASCII.LF &
        "      type Rec is record" & ASCII.LF &
        "         A : Integer;" & ASCII.LF &
        "      end record;" & ASCII.LF &

package body Editor.Syntax_Semantics.Representation_Misc_Unification_Tests is

   procedure Test_Language_Model_Default_SSO_Dimension_Unification_Pass
     (T : in out AUnit.Test_Cases.Test_Case'Class) is
      pragma Unreferenced (T);
      Source : constant String :=
        "package P with Default_Scalar_Storage_Order => High_Order_First is" & ASCII.LF &
        "   for P'Default_Scalar_Storage_Order use Low_Order_First;" & ASCII.LF &
        "   type Distance is new Integer with" & ASCII.LF &
        "     Dimension_System => ((Unit_Name => Meter, Unit_Symbol => ""m"", Dim_Symbol => 'L'));" & ASCII.LF &
        "   for Distance'Dimension_System use ((Unit_Name => Meter, Unit_Symbol => ""m"", Dim_Symbol => 'L'));" & ASCII.LF &
        "   type Speed is new Integer with Dimension => (Meter => 1);" & ASCII.LF &
        "   for Speed'Dimension use (Meter => 1);" & ASCII.LF &
        "end P;" & ASCII.LF;
      Analysis : constant Editor.Ada_Language_Model.Analysis_Result :=
        Editor.Ada_Declaration_Parser.Parse (Source);
      use type Editor.Ada_Language_Model.Representation_Clause_Kind;
      Package_Id : constant Editor.Ada_Language_Model.Symbol_Id :=
        Editor.Ada_Symbol_Resolver.First_Match (Analysis, "P");
      Distance_Id : constant Editor.Ada_Language_Model.Symbol_Id :=
        Editor.Ada_Symbol_Resolver.First_Match (Analysis, "Distance");
      Speed_Id : constant Editor.Ada_Language_Model.Symbol_Id :=
        Editor.Ada_Symbol_Resolver.First_Match (Analysis, "Speed");
      Seen_Default_SSO_Aspect : Boolean := False;
      Seen_Default_SSO_Clause : Boolean := False;
      Seen_Dimension_System_Aspect : Boolean := False;
      Seen_Dimension_System_Clause : Boolean := False;
      Seen_Dimension_Aspect : Boolean := False;
      Seen_Dimension_Clause : Boolean := False;
   begin
      Assert (Package_Id /= Editor.Ada_Language_Model.No_Symbol,
              "package target should be retained for Default_Scalar_Storage_Order");
      Assert (Distance_Id /= Editor.Ada_Language_Model.No_Symbol,
              "dimension-system type target should be retained");
      Assert (Speed_Id /= Editor.Ada_Language_Model.No_Symbol,
              "dimension type target should be retained");

      for I in 1 .. Editor.Ada_Language_Model.Representation_Clause_Count (Analysis) loop
         declare
            R : constant Editor.Ada_Language_Model.Representation_Clause_Info :=
              Editor.Ada_Language_Model.Representation_Clause_At
                (Analysis, Editor.Ada_Language_Model.No_Symbol, I);
            Item : constant String := To_String (R.Item_Text);
         begin
            if R.Target_Symbol = Package_Id
              and then R.Kind = Editor.Ada_Language_Model.Representation_Default_Scalar_Storage_Order_Clause
            then
               if Item = "High_Order_First" then
                  Seen_Default_SSO_Aspect := True;
               elsif Item = "Low_Order_First" then
                  Seen_Default_SSO_Clause := True;
               end if;
            elsif R.Target_Symbol = Distance_Id
              and then R.Kind = Editor.Ada_Language_Model.Representation_Dimension_System_Clause
            then
               if Seen_Dimension_System_Aspect then
                  Seen_Dimension_System_Clause := True;
               else
                  Seen_Dimension_System_Aspect := True;
               end if;
            elsif R.Target_Symbol = Speed_Id
              and then R.Kind = Editor.Ada_Language_Model.Representation_Dimension_Clause
            then
               if Seen_Dimension_Aspect then
                  Seen_Dimension_Clause := True;
               else
                  Seen_Dimension_Aspect := True;
               end if;
            end if;
         end;
      end loop;

      Assert (Seen_Default_SSO_Aspect and then Seen_Default_SSO_Clause,
              "Default_Scalar_Storage_Order aspect and attribute clause should share explicit kind");
      Assert (Seen_Dimension_System_Aspect and then Seen_Dimension_System_Clause,
              "Dimension_System aspect and attribute clause should share explicit kind");
      Assert (Seen_Dimension_Aspect and then Seen_Dimension_Clause,
              "Dimension aspect and attribute clause should share explicit kind");
   end Test_Language_Model_Default_SSO_Dimension_Unification_Pass;

   procedure Test_Language_Model_Resolver_Driven_Property_Unification_Pass
     (T : in out AUnit.Test_Cases.Test_Case'Class) is
      pragma Unreferenced (T);
      Source : constant String :=
        "package P with Suppress_Debug_Info is" & ASCII.LF &
        "   for P'Suppress_Debug_Info use True;" & ASCII.LF &
        "   type Pool is new Integer with Simple_Storage_Pool_Type;" & ASCII.LF &
        "   for Pool'Simple_Storage_Pool_Type use True;" & ASCII.LF &
        "   type Vol is new Integer with Atomic_Always_Lock_Free;" & ASCII.LF &
        "   for Vol'Atomic_Always_Lock_Free use True;" & ASCII.LF &
        "end P;" & ASCII.LF;
      Analysis : constant Editor.Ada_Language_Model.Analysis_Result :=
        Editor.Ada_Declaration_Parser.Parse (Source);
      use type Editor.Ada_Language_Model.Representation_Clause_Kind;
      Package_Id : constant Editor.Ada_Language_Model.Symbol_Id :=
        Editor.Ada_Symbol_Resolver.First_Match (Analysis, "P");
      Pool_Id : constant Editor.Ada_Language_Model.Symbol_Id :=
        Editor.Ada_Symbol_Resolver.First_Match (Analysis, "Pool");
      Vol_Id : constant Editor.Ada_Language_Model.Symbol_Id :=
        Editor.Ada_Symbol_Resolver.First_Match (Analysis, "Vol");
      Seen_Debug_Info : Natural := 0;
      Seen_Simple_Pool : Natural := 0;
      Seen_Always_Lock_Free : Natural := 0;
   begin
      Assert (Package_Id /= Editor.Ada_Language_Model.No_Symbol,
              "package target should be retained for resolver-driven property recognition");
      Assert (Pool_Id /= Editor.Ada_Language_Model.No_Symbol,
              "storage-pool type target should be retained");
      Assert (Vol_Id /= Editor.Ada_Language_Model.No_Symbol,
              "atomic lock-free type target should be retained");

      for I in 1 .. Editor.Ada_Language_Model.Representation_Clause_Count (Analysis) loop
         declare
            R : constant Editor.Ada_Language_Model.Representation_Clause_Info :=
              Editor.Ada_Language_Model.Representation_Clause_At
                (Analysis, Editor.Ada_Language_Model.No_Symbol, I);
            Item : constant String := To_String (R.Item_Text);
         begin
            if R.Target_Symbol = Package_Id
              and then R.Kind = Editor.Ada_Language_Model.Representation_Suppress_Debug_Info_Clause
              and then Item = "True"
            then
               Seen_Debug_Info := Seen_Debug_Info + 1;
            elsif R.Target_Symbol = Pool_Id
              and then R.Kind = Editor.Ada_Language_Model.Representation_Simple_Storage_Pool_Type_Clause
              and then Item = "True"
            then
               Seen_Simple_Pool := Seen_Simple_Pool + 1;
            elsif R.Target_Symbol = Vol_Id
              and then R.Kind = Editor.Ada_Language_Model.Representation_Atomic_Always_Lock_Free_Clause
              and then Item = "True"
            then
               Seen_Always_Lock_Free := Seen_Always_Lock_Free + 1;
            end if;
         end;
      end loop;

      Assert (Seen_Debug_Info = 2,
              "Suppress_Debug_Info bare aspect and attribute clause should share resolver-derived kind and Boolean default");
      Assert (Seen_Simple_Pool = 2,
              "Simple_Storage_Pool_Type bare aspect and attribute clause should share resolver-derived kind and Boolean default");
      Assert (Seen_Always_Lock_Free = 2,
              "Atomic_Always_Lock_Free bare aspect and attribute clause should share resolver-derived kind and Boolean default");
   end Test_Language_Model_Resolver_Driven_Property_Unification_Pass;

   overriding function Name (T : RepresentationMiscUnification_Test_Case) return AUnit.Message_String is
   begin
      return AUnit.Format ("Representation-Misc-Unification");
   end Name;

   overriding procedure Register_Tests (T : in out RepresentationMiscUnification_Test_Case) is
      procedure Add_Test
        (Routine : AUnit.Test_Cases.Test_Routine; Name : String) is
      begin
         AUnit.Test_Cases.Registration.Register_Routine (T, Routine, Name);
      end Add_Test;
   begin
      Add_Test (Routine => Test_Language_Model_Default_SSO_Dimension_Unification_Pass'Access, Name => "language model unifies default scalar storage order and dimension properties");
      Add_Test (Routine => Test_Language_Model_Resolver_Driven_Property_Unification_Pass'Access, Name => "language model uses the shared resolver for aspect recognition and Boolean defaults");
   end Register_Tests;

end Editor.Syntax_Semantics.Representation_Misc_Unification_Tests;
